# Копируйте в .env при запуске catalog-service локально (mvn spring-boot:run или IDE).
# Файл .env в git не попадает.
#
# Создание пользователя и БД локально (PostgreSQL уже установлен, например Homebrew):
#   createdb catalog
#   createuser -P catalog_user   # введите пароль: catalog_pass
#   psql -d catalog -c "GRANT ALL PRIVILEGES ON DATABASE catalog TO catalog_user;"
#   psql -d catalog -c "GRANT ALL ON SCHEMA public TO catalog_user;"
#   psql -d catalog -c "ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON TABLES TO catalog_user;"
#
# Или одной командой (под суперпользователем, замените $USER на вашего pg-пользователя):
#   psql -U $USER postgres -c "CREATE USER catalog_user WITH PASSWORD 'catalog_pass' CREATEDB;"
#   psql -U $USER postgres -c "CREATE DATABASE catalog OWNER catalog_user;"
#
# Для mvn spring-boot:run переменные из .env не подхватываются автоматически:
#   export $(grep -v '^#' .env | xargs)
#   mvn spring-boot:run

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=catalog
POSTGRES_USER=catalog_user
POSTGRES_PASSWORD=catalog_pass
