# Копируйте в .env и при необходимости измените значения.
# Файл .env в git не попадает (см. .gitignore).

# --- Локальный запуск (приложение подключается к БД на localhost) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=catalog
POSTGRES_USER=catalog_user
POSTGRES_PASSWORD=catalog_pass

# --- Docker: эти переменные заданы в docker-compose.yml для catalog-service ---
# В контейнере POSTGRES_HOST=postgres (имя сервиса). Создавать .env для Docker не обязательно.
